# StackHawk environment variables — DO NOT COMMIT
# Copy this to .env.hawk and fill in values
# Add .env.hawk to .gitignore

# Get from app.stackhawk.com -> Settings -> API Keys
HAWK_API_KEY=hawk.replace_with_your_api_key

# Get from app.stackhawk.com -> Applications -> clinic-notes-ai -> App ID
APP_ID=replace_with_your_app_id

# Target URL for scan
APP_BASE_URL=http://localhost:3000

# Environment label shown in StackHawk dashboard
APP_ENV=local

# Valid cna_session cookie from a logged-in browser session
# How to get it:
#   1. Log in to the app in your browser
#   2. DevTools -> Application -> Cookies -> your domain
#   3. Copy the value of the cna_session cookie
SESSION_COOKIE=replace_with_session_cookie_value
