# Production environment variables — Clinic Notes AI
# Copy to .env.production and fill in real values.
# NEVER commit .env.production itself.

# Supabase (production project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_SITE_URL=https://clinic-notes-ai.vercel.app

# AI APIs
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Sentry (add after installation)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# Internal runner authentication
JOBS_RUNNER_TOKEN=

# Cron secret (Vercel cron)
CRON_SECRET=