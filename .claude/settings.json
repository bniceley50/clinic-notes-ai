{
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run test*)",
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git status)",
      "Bash(git show*)",
      "Bash(ls*)",
      "Bash(cat src/*)",
      "Bash(npx tsc --noEmit)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets/**)",
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(supabase db reset*)",
      "Bash(npx supabase*)",
      "Bash(curl* SUPABASE_SERVICE_ROLE*)",
      "Bash(printenv*)",
      "Bash(env)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/pre-tool.sh"
          }
        ]
      }
    ]
  },
  "model": "claude-sonnet-4-6",
  "autoMemoryEnabled": false,
  "respectGitignore": true
}
